# Split.io Integration Test Configuration
# Copy this file to .env and fill in values from your Split.io account

# SDK API Key (from Split.io Console > Admin Settings > API Keys)
# This is the key used by the SDK to fetch feature flags
SPLIT_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Admin API Key (from Split.io Console > Admin Settings > API Keys)
# This is used to create/modify test fixtures via the Admin API
# Must have write permissions for feature flags and segments
SPLIT_ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Workspace (Project) ID
# Found in Split.io Console URL: app.split.io/org/{org}/ws/{WORKSPACE_ID}
SPLIT_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Environment ID
# Found in Split.io Console > Admin Settings > Environments
SPLIT_ENVIRONMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Environment Name (must match the environment associated with SPLIT_SDK_KEY)
SPLIT_ENVIRONMENT_NAME=integration-test

# Traffic Type (usually "user" - must exist in your workspace)
SPLIT_TRAFFIC_TYPE=user
